# ═══════════════════════════════════════════════════════════════════
# FRONTEND — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE PAS committer .env dans Git !
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# API Backend
# ─────────────────────────────────────────────

# URL du backend Django
# En local :
VITE_API_URL=http://localhost:8000/api/v1

# En production (décommenter et adapter) :
# VITE_API_URL=https://ifpmeb-backend.vercel.app/api/v1

# ─────────────────────────────────────────────
# Informations du site (optionnel)
# ─────────────────────────────────────────────

# Nom du site affiché dans les métadonnées
# VITE_SITE_NAME=IFPMEB

# URL publique du frontend (pour les liens canoniques, partages sociaux...)
# VITE_SITE_URL=https://ifpmeb.vercel.app
